# =====================================================
# Azarean Rehab — Production .env
# -----------------------------------------------------
# Файл на VDS: /opt/azarean-rehab/backend/.env
# (шаблон называется .env.production.example, при setup
#  копируется в .env, секреты заполняются вручную)
#
# Владелец файла: root, права 600 (-rw-------)
#   chown root:root .env && chmod 600 .env
# =====================================================

NODE_ENV=production
PORT=3001

# ─── PostgreSQL ─────────────────────────────────────────
# БД создаётся в setup.sh командой CREATE DATABASE azarean_rehab OWNER azarean_user
DB_HOST=localhost
DB_PORT=5432
DB_NAME=azarean_rehab
DB_USER=azarean_user
DB_PASSWORD=<CHANGE_ME_32_CHARS>

# ─── JWT / Auth ─────────────────────────────────────────
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Каждый секрет — отдельный 64-hex (32 bytes entropy).
JWT_SECRET=<CHANGE_ME_64_HEX>
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

PATIENT_JWT_SECRET=<CHANGE_ME_64_HEX_DIFFERENT>
PATIENT_JWT_EXPIRES_IN=15m
PATIENT_REFRESH_EXPIRES_IN=30d

SESSION_SECRET=<CHANGE_ME_64_HEX_DIFFERENT>

# ─── Kinescope ──────────────────────────────────────────
KINESCOPE_API_KEY=<KINESCOPE_API_KEY_FROM_DEV_OR_NEW>
KINESCOPE_PROJECT_ID=<KINESCOPE_PROJECT_ID>

# ─── CORS / Frontend ────────────────────────────────────
# Single-origin setup: frontend и backend на одном домене my.azarean.ru
# CORS работает для любого origin на этом же домене.
CORS_ORIGINS=https://my.azarean.ru
FRONTEND_URL=https://my.azarean.ru

# ─── Telegram (prod-бот, НЕ dev!) ───────────────────────
# Токен prod-бота: @az_zari_bot — отдельный от @azarean_rehab_bot (dev).
# Два бота = два параллельных polling-процесса без конфликта.
TELEGRAM_BOT_TOKEN=<PROD_BOT_TOKEN>
TELEGRAM_BOT_USERNAME=az_zari_bot

# ─── Optional ──────────────────────────────────────────
# BASE_URL используется для email password-reset ссылок
BASE_URL=https://my.azarean.ru
