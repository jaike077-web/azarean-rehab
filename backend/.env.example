# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=azarean_rehab
DB_USER=postgres
DB_PASSWORD=

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Kinescope API (if used)
KINESCOPE_API_KEY=
KINESCOPE_PROJECT_ID=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=

# Observability
# DSN с sentry.io (Settings → Projects → [project] → Client Keys).
# Если пусто — Sentry SDK работает в noop-режиме (dev/test).
# Замечание: sentry.io ingest заблокирован для русских IP. До поднятия
# proxy через JARVIS-Финляндию остаётся пустым, основной канал — ops-bot ниже.
SENTRY_DSN=

# Telegram ops-bot для уведомлений об ошибках. Параллельный канал к Sentry,
# работает с rehab-VDS и от пациентов в РФ (Telegram API не блокируется).
# Создание: @BotFather → /newbot → @azarean_ops_bot → получить token.
# OPS_CHAT_ID: написать боту /start, затем GET https://api.telegram.org/bot<TOKEN>/getUpdates
# и взять message.chat.id из последнего апдейта (для DM = собственный user_id).
# Если оба пусты — opsAlert пишет в console.log (noop, dev/test).
OPS_BOT_TOKEN=
OPS_CHAT_ID=

# Email (Resend)
# API key с resend.com. Если пусто — emails логируются в console (dev/test).
# Domain my.azarean.ru должен быть верифицирован в Resend (SPF/DKIM/DMARC в Reg.ru).
RESEND_API_KEY=
EMAIL_FROM=Azarean <noreply@my.azarean.ru>
