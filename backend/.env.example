# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=azarean_rehab
DB_USER=postgres
DB_PASSWORD=

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Kinescope API (if used)
KINESCOPE_API_KEY=
KINESCOPE_PROJECT_ID=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=

# Telegram Bot API base URL — fallback на reverse-proxy через зарубежный VDS
# когда NetAngels блокирует api.telegram.org по SNI (инцидент 2026-05-22).
# Пусто → node-telegram-bot-api идёт напрямую (дефолт на dev).
# Prod значение: https://tg-proxy.azarean.ru/tg (БЕЗ trailing slash — node-telegram-bot-api
# делает string concat, slash сломает; Telegraf наоборот требует slash).
TELEGRAM_API_URL=

# Observability
# DSN с sentry.io (Settings → Projects → [project] → Client Keys).
# Если пусто — Sentry SDK работает в noop-режиме (dev/test).
# Замечание: sentry.io ingest заблокирован для русских IP. До поднятия
# proxy через JARVIS-Финляндию остаётся пустым, основной канал — ops-bot ниже.
SENTRY_DSN=

# Telegram ops-bot для уведомлений об ошибках. Параллельный канал к Sentry,
# работает с rehab-VDS и от пациентов в РФ (Telegram API не блокируется).
# Создание: @BotFather → /newbot → @azarean_ops_bot → получить token.
# OPS_CHAT_ID: написать боту /start, затем GET https://api.telegram.org/bot<TOKEN>/getUpdates
# и взять message.chat.id из последнего апдейта (для DM = собственный user_id).
# Если оба пусты — opsAlert пишет в console.log (noop, dev/test).
OPS_BOT_TOKEN=
OPS_CHAT_ID=

# Email — two-tier: Yandex 360 (primary) → Resend (fallback) → console.log stub
#
# Yandex 360 SMTP — основной канал для пациентов в РФ (yandex.ru / mail.ru).
# Покупаем в Yandex 360 для бизнеса (149₽/мес), создаём ящик
# noreply@my.azarean.ru, генерируем app-password в id.yandex.ru.
# DNS Reg.ru: SPF + DKIM от Yandex (см. админка Y360 → Домены → DKIM).
YANDEX_SMTP_USER=
YANDEX_SMTP_PASSWORD=

# Resend — резерв на случай если Y360 SMTP лежит / письмо в зарубежный
# домен не доставляется. Free 3000/мес. ⚠️ Серверы в США — трансграничная
# передача персональных данных, при коммерческом запуске нужно уведомление
# Роскомнадзора + согласие пациента. Пока пилот — резерв OK.
# DNS Reg.ru: SPF + DKIM от Resend (см. resend.com/domains). SPF объединяется
# с Yandex одной строкой: v=spf1 include:_spf.yandex.net include:_spf.resend.com ~all
RESEND_API_KEY=

# Если оба пусты — emails логируются в console (dev/test). Это OK для разработки,
# но password reset на проде не будет работать пока хотя бы один не настроен.
EMAIL_FROM=Azarean <noreply@my.azarean.ru>

# is*ai (LLM хостера is*hosting, OpenAI-совместимый, Open WebUI+Ollama).
# Структурирование надиктовки упражнений (текст → поля). ТОЛЬКО не-PII контент
# библиотеки — данные пациентов сюда НЕ шлём (is*ai физически вне РФ, Гонконг).
# Ключ: ai.ishosting.com → Settings → Account → API Keys → Show.
# Пусто → POST /api/exercises/structure отдаёт 503 (фича выключена).
ISAI_API_KEY=
ISAI_BASE_URL=https://ai.ishosting.com/api
ISAI_MODEL=qwen3:latest

# DeepSeek (OpenAI-совместимый, https://api.deepseek.com) — ОСНОВНОЙ LLM для
# структурирования надиктовки (качественнее бесплатных is*hosting-моделей).
# Контент упражнений = не-PII. Модели: deepseek-v4-flash (быстрая) / deepseek-v4-pro.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Сильная модель под генерацию (планировщик скрипта, этап 4). Опционально — есть дефолт.
DEEPSEEK_MODEL_PRO=deepseek-v4-pro
# Провайдер структурирования: deepseek (по умолчанию) | isai
STRUCTURE_LLM_PROVIDER=deepseek

# Yandex SpeechKit (STT) — распознавание надиктовки. Каталог cloud-jaike077 (РФ).
# Сервисный аккаунт с ролью ai.speechkit-stt.user → API-ключ (Api-Key header).
# Контент упражнений = не PII. Пусто → POST /api/exercises/transcribe отдаёт 503.
YANDEX_SPEECHKIT_API_KEY=
YANDEX_SPEECHKIT_FOLDER_ID=
YANDEX_SPEECHKIT_LANG=ru-RU
