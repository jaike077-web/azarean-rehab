# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=azarean_rehab
DB_USER=postgres
DB_PASSWORD=

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Kinescope API (if used)
KINESCOPE_API_KEY=
KINESCOPE_PROJECT_ID=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=

# Observability
# DSN с sentry.io (Settings → Projects → [project] → Client Keys).
# Если пусто — Sentry SDK работает в noop-режиме (dev/test).
# Замечание: sentry.io ingest заблокирован для русских IP. До поднятия
# proxy через JARVIS-Финляндию остаётся пустым, основной канал — ops-bot ниже.
SENTRY_DSN=

# Telegram ops-bot для уведомлений об ошибках. Параллельный канал к Sentry,
# работает с rehab-VDS и от пациентов в РФ (Telegram API не блокируется).
# Создание: @BotFather → /newbot → @azarean_ops_bot → получить token.
# OPS_CHAT_ID: написать боту /start, затем GET https://api.telegram.org/bot<TOKEN>/getUpdates
# и взять message.chat.id из последнего апдейта (для DM = собственный user_id).
# Если оба пусты — opsAlert пишет в console.log (noop, dev/test).
OPS_BOT_TOKEN=
OPS_CHAT_ID=

# Email — two-tier: Yandex 360 (primary) → Resend (fallback) → console.log stub
#
# Yandex 360 SMTP — основной канал для пациентов в РФ (yandex.ru / mail.ru).
# Покупаем в Yandex 360 для бизнеса (149₽/мес), создаём ящик
# noreply@my.azarean.ru, генерируем app-password в id.yandex.ru.
# DNS Reg.ru: SPF + DKIM от Yandex (см. админка Y360 → Домены → DKIM).
YANDEX_SMTP_USER=
YANDEX_SMTP_PASSWORD=

# Resend — резерв на случай если Y360 SMTP лежит / письмо в зарубежный
# домен не доставляется. Free 3000/мес. ⚠️ Серверы в США — трансграничная
# передача персональных данных, при коммерческом запуске нужно уведомление
# Роскомнадзора + согласие пациента. Пока пилот — резерв OK.
# DNS Reg.ru: SPF + DKIM от Resend (см. resend.com/domains). SPF объединяется
# с Yandex одной строкой: v=spf1 include:_spf.yandex.net include:_spf.resend.com ~all
RESEND_API_KEY=

# Если оба пусты — emails логируются в console (dev/test). Это OK для разработки,
# но password reset на проде не будет работать пока хотя бы один не настроен.
EMAIL_FROM=Azarean <noreply@my.azarean.ru>
