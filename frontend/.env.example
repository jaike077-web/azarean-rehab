# API Endpoint
REACT_APP_API_URL=http://localhost:5000

# Kinescope (if accessed from frontend)
REACT_APP_KINESCOPE_PROJECT_ID=

# Observability
# Отдельный Sentry-проект для frontend (Settings → Projects → React project).
# Если пусто — Sentry SDK не инициализируется (dev/test).
REACT_APP_SENTRY_DSN=

# Wave 2 #2.05 — телефон куратора для banner'а в PainEventForm
# (показывается пациенту если за последний час уже был red-flag alert).
# E.164 формат. Пустой → tel: ссылка без значения.
REACT_APP_CURATOR_PHONE=
