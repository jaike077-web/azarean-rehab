# Shell-скрипты и все файлы deploy/ — всегда LF (иначе bash на Linux не запустит).
*.sh              text eol=lf
deploy/*          text eol=lf
deploy/**/*       text eol=lf
*.conf            text eol=lf
Dockerfile        text eol=lf
.github/**/*.yml  text eol=lf
# SQL миграции / schema / seeds — LF, чтобы checksum в deploy/migrate.sh
# был платформонезависимым. Без этого Windows working tree с core.autocrlf=true
# получал CRLF → sha256sum != stored (посчитанный на Linux). См. фикс migrate.sh
# (strip-CR перед sha256) и hotfix/migration-checksum-hygiene.
*.sql             text eol=lf
# Git-Hygiene Kit — детектор потерянной работы + журнал разобранных сирот (LF).
scripts/.lost-work-ack  text eol=lf
